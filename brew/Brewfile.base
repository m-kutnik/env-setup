brew "zoxide" # modern replacement for cd https://github.com/ajeetdsouza/zoxide
brew "eza" # modern replacement for ls https://github.com/eza-community/eza
brew "chafa" # images in the terminal https://github.com/hpjansson/chafa
brew "mise" # development multi-tool https://github.com/jdx/mise
brew "shfmt" # formatter for shell scripts https://github.com/mvdan/sh
brew "wget"
brew "mas" # Mac App Store CLI https://github.com/mas-cli/mas
brew "bitwarden-cli" # Bitwarden CLI https://github.com/bitwarden/cli

# make yubikey work with ssh agent
brew "yubico-piv-tool"
brew "libfido2"

cask "font-jetbrains-mono-nerd-font"
cask "font-meslo-for-powerlevel10k"
